{
	"compilerOptions": {
		"allowSyntheticDefaultImports": true,
		"declaration": true,
		"declarationDir": "./dist/types",
		"declarationMap": true,
		"emitDeclarationOnly": false,
		"esModuleInterop": true,
		"experimentalDecorators": true,
		"importHelpers": true,
		"incremental": true,
		"inlineSources": true,
		"lib": ["es2021", "dom"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmitOnError": true,
		"outDir": "dist",
		"paths": { "*": ["./src/*", "./tests/*", "./stories/*"] },
		"resolveJsonModule": true,
		"rootDir": "./",
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": true,
		"target": "es2021",
		"types": ["node"]
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "dist"],
	"plugins": [
		{
			"name": "ts-lit-plugin",
			"strict": true
		}
	]
}
