{
	"name": "fhir-beacon",
	"version": "0.2.0",
	"license": "MIT",
	"homepage": "https://fhir-beacon.deno.dev",
	"repository": {
		"url": "https://github.com/zenwork/fhir-beacon.git",
		"type": "git",
		"directory": "packages/library"
	},
	"author": "Florian Hehlen",
	"description": "A library for working with FHIR data in the browser without the need for a backend.",
	"type": "module",
	"browser": "dist/fhir-beacon.js",
	"module": "dist/fhir-beacon.js",
	"types": "dist/types/index.d.ts",
	"files": [
		"dist/**/*",
		"build/web-types.json",
		"build/custom-elements.json",
		"README.md"
	],
	"keywords": [
		"fhir",
		"web components",
		"custom elements",
		"lit",
		"web"
	],
	"scripts": {
		"build": "vite build && tsc -p tsconfig.build.json",
		"start": "storybook dev -p 9999",
		"test": "HEADLESS=true vitest run --config vitest.workspace.ts",
		"publish": "echo publish",
		"generate-barrels": "barrelsby --delete --config autobarrel.json --location replace --noSemicolon --singleQuotes",
		"manifest::build": "cem analyze --config build/custom-elements-manifest.config.js ",
		"manifest::watch": "cem analyze --config build/custom-elements-manifest.config.js --watch",
		"storybook": "storybook dev -p 9999 --no-open",
		"storybook::build": "storybook build",
		"storybook:clean": "rm -rf node_modules/.cache/storybook",
		"build-storybook": "storybook build",
		"tsc": "tsc -p tsconfig.build.json",
		"tsc::watch": "tsc -p tsconfig.build.json --watch",
		"tsc::types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
		"vite::build": "vite build && tsc -p tsconfig.build.json",
		"vite::dev": "vite",
		"vite::preview": "vite preview",
		"vitest": "HEADLESS=true vitest run --config vitest.workspace.ts",
		"vitest::debug": "vitest watch --config vitest.workspace.ts",
		"vitest::coverage": "NODE_ENV=production HEADLESS=true vitest --config vitest.workspace.ts --coverage",
		"vitest::dev": "NODE_ENV=production HEADLESS=true vitest watch --config vitest.workspace.ts --mode production ",
		"test:browser": "HEADLESS=true vitest run --config vitest.workspace.ts --project browser"
	},
	"dependencies": {
		"@lit/context": "^1.1.5",
		"@shoelace-style/shoelace": "^2.20.1",
		"axios": "^1.9.0",
		"full-icu": "^1.5.0",
		"jsonpath-plus": "^10.3.0",
		"lit": "^3.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@changesets/cli": "^2.31.0",
		"@chromatic-com/storybook": "^5.1.2",
		"@custom-elements-manifest/analyzer": "^0.11.0",
		"@open-wc/semantic-dom-diff": "^0.20.1",
		"@storybook/addon-docs": "^10.3.6",
		"@storybook/addon-links": "^10.3.6",
		"@storybook/web-components": "^10.3.6",
		"@storybook/web-components-vite": "^10.3.6",
		"@testing-library/dom": "^10.4.1",
		"@types/node": "^22.14.1",
		"@types/query-selector-shadow-dom": "^1.0.4",
		"@vitest/browser": "^4.1.5",
		"@vitest/browser-playwright": "^4.1.5",
		"@vitest/coverage-v8": "^4.1.5",
		"@vitest/ui": "^4.1.5",
		"@wc-toolkit/cem-inheritance": "^1.2.2",
		"@wc-toolkit/storybook-helpers": "^10.3.0",
		"@web-types/lit": "^2.0.0-3",
		"@web/dev-server": "^0.4.6",
		"@web/dev-server-esbuild": "^1.0.5",
		"@web/dev-server-rollup": "^0.6.4",
		"@whitespace/storybook-addon-html": "^9.0.0",
		"barrelsby": "^2.8.1",
		"concurrently": "^9.1.2",
		"custom-element-jet-brains-integration": "^1.7.0",
		"dotenv": "^17.4.2",
		"globals": "^17.6.0",
		"html-format": "^1.1.7",
		"lit-html": "^3.3.2",
		"playwright": "^1.59.1",
		"query-selector-shadow-dom": "^1.0.1",
		"remark-gfm": "^4.0.1",
		"shadow-dom-selector": "^6.1.0",
		"shadow-dom-testing-library": "^1.13.1",
		"storybook": "^10.3.6",
		"ts-lit-plugin": "^2.0.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vite-plugin-cem": "^0.8.5",
		"vite-plugin-ts": "^1.3.2-1",
		"vitest": "^4.1.5"
	},
	"publishConfig": {
		"access": "public"
	},
	"web-types": [
		"./build/sl-web-types.json",
		"./build/web-types.json"
	]
}
